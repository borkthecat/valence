# Copy to .env and fill in real values. Do not commit .env.

# --- Gateway (TypeScript) ---
GATEWAY_PORT=8080
UPSTREAM_PROVIDER_URL=https://api.anthropic.com
UPSTREAM_API_KEY=replace-with-provider-key
GATEWAY_API_KEY=replace-with-a-random-32-plus-character-secret
SECURITY_MODE=FAIL_CLOSED
MAX_PAYLOAD_KB=512
NODE_ENV=production

# --- Pipeline (Python) ---
TARGET_ERA=1500
TARGET_CHANNEL=direct
TARGET_COLORWAY=midnight-sapphire
AUTHORIZED_CHANNELS=direct,brand-direct,certified-partner,boutique-authorized
MAX_FIELD_BYTES=512

# Where Stage 5 reaches the gateway. Use "gateway" under docker-compose,
# or "localhost" when running both processes directly on the host.
PROXY_HOST=gateway
PROXY_PORT=8080
