# Copy to .env and fill in real values. Do not commit .env.

# --- Gateway (TypeScript) ---
VALENCE_VERSION=1.11.8
GATEWAY_PORT=8080
UPSTREAM_PROVIDER_URL=https://api.anthropic.com
UPSTREAM_API_KEY=replace-with-provider-key
GATEWAY_API_KEY=replace-with-a-random-32-plus-character-secret
SECURITY_MODE=FAIL_CLOSED
MODEL_SERVICE_TIMEOUT_MS=3000
EVIDENCE_URL_VALIDATION=syntax
EVIDENCE_URL_TIMEOUT_MS=3000
MAX_LIVE_EVIDENCE_URLS=100
# PII_CLASSIFIER_URL=https://pii.internal.example/v1/classify
# PII_CLASSIFIER_API_KEY=replace-with-classifier-service-secret
# GUARD_MODEL_URL=https://guard.internal.example/v1/assess
# GUARD_MODEL_API_KEY=replace-with-guard-service-secret
GUARD_USER_POLICY=direct
GUARD_MODEL_PATH=models/prompt-injection-guard.json
GUARD_MODEL_SHA256=c9e6888213773172ff6127d1165146f02cb03d079d8011b6e20429e0d9bcec02
AUTH_MODE=api_key
# Optional: load UPSTREAM_API_KEY, GATEWAY_API_KEY, JWT_SECRET, and/or
# JWT_PUBLIC_KEY_PEM from a local JSON file instead of this environment file.
# SECRETS_FILE_PATH=/run/secrets/valence-gateway.json
# Required only when AUTH_MODE=jwt. Prefer RS256 with JWT_PUBLIC_KEY_PEM for IdP-backed deployments.
JWT_ALGORITHM=HS256
ENTERPRISE_INGEST_AUTH_MODE=jwks
# Required for production enterprise ingestion when ENTERPRISE_INGEST_AUTH_MODE=jwks.
# JWKS_URI=https://auth.example.com/.well-known/jwks.json
# JWT_AUDIENCE=https://api.example.com
# JWT_ISSUER=https://auth.example.com/
# JWT_SECRET=replace-with-a-random-32-plus-character-hmac-secret
# JWT_PUBLIC_KEY_PEM=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
JWT_REQUIRED_SCOPE=valence:proxy
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
AUDIT_LOG_PATH=audit/valence-audit.log
MAX_PAYLOAD_KB=512
NODE_ENV=production

# --- Pipeline (Python) ---
TARGET_ERA=1500
TARGET_CHANNEL=direct
TARGET_COLORWAY=midnight-sapphire
AUTHORIZED_CHANNELS=direct,brand-direct,certified-partner,boutique-authorized
MAX_FIELD_BYTES=512
VALENCE_SCALE_VALIDATION_PROFILES=2000000
VALENCE_SCALE_VALIDATION_WINDOW=100000
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_INGEST_TOPIC=valence-raw-profiles
KAFKA_DLQ_TOPIC=valence-profile-dlq
IDEMPOTENCY_TTL_SECONDS=604800
KAFKA_CONSUMER_GROUP=valence-core-pipeline-workers
REDIS_URL=redis://redis:6379

# Where Stage 5 reaches the gateway. Use "gateway" under docker-compose,
# or "localhost" when running both processes directly on the host.
PROXY_HOST=gateway
PROXY_PORT=8080

# --- Observability and testing ---
# Emit machine-readable JSON logs to stderr (for Datadog/Splunk/Cloud Logging).
VALENCE_JSON_LOGS=false
# Intercept outbound AI calls locally with deterministic mock responses.
# Keep true for local demo/testing; set false in production to route through the gateway.
MOCK_AI_PROVIDER=true
